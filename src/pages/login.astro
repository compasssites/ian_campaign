---
import Shell from "../layouts/Shell.astro";
import { getSession, getTokenFromCookie } from "../lib/auth/session";

const runtime = Astro.locals.runtime;
const env = runtime?.env as Env | undefined;
const token = getTokenFromCookie(Astro.request.headers.get("Cookie"));
const session = env?.SESSIONS ? await getSession(env.SESSIONS, token) : null;
if (session) return Astro.redirect("/dashboard");
---
<Shell title="Login — IAN Campaign">
<style>
  .login-page {
    min-height: 100vh;
    background: linear-gradient(160deg, #0f2044 0%, #1a3a6b 50%, #1e4d8c 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
  }
  .login-wrap { width: 100%; max-width: 360px; }
  .login-brand { text-align: center; margin-bottom: 32px; }
  .login-icon {
    width: 72px; height: 72px;
    background: white;
    border-radius: 20px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    font-size: 36px;
  }
  .login-title { color: white; font-size: 26px; font-weight: 700; margin: 0 0 4px; letter-spacing: -0.3px; }
  .login-sub { color: rgba(255,255,255,0.6); font-size: 14px; margin: 0; }
  .login-card {
    background: white;
    border-radius: 24px;
    padding: 28px 24px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }
  .field { margin-bottom: 16px; }
  .field label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }
  .field input {
    width: 100%; padding: 14px 16px;
    border: 1.5px solid #e5e7eb;
    border-radius: 14px;
    font-size: 16px; color: #111827;
    background: #f9fafb;
    outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
  }
  .field input:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.12); background: white; }
  .login-btn {
    width: 100%; padding: 15px;
    background: linear-gradient(135deg, #1e3a8a, #2563eb);
    color: white; border: none; border-radius: 14px;
    font-size: 16px; font-weight: 700;
    cursor: pointer; margin-top: 8px;
    box-shadow: 0 4px 14px rgba(37,99,235,0.4);
    transition: opacity 0.15s, transform 0.1s;
  }
  .login-btn:active { opacity: 0.85; transform: scale(0.99); }
  .login-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .login-err {
    display: none; margin-top: 12px;
    background: #fef2f2; border: 1px solid #fecaca;
    color: #dc2626; font-size: 14px; text-align: center;
    padding: 10px 14px; border-radius: 10px;
  }
</style>

<div class="login-page">
  <div class="login-wrap">
    <div class="login-brand">
      <div class="login-icon">📞</div>
      <h1 class="login-title">IAN Campaign</h1>
      <p class="login-sub">Campaign Calling Dashboard</p>
    </div>
    <div class="login-card">
      <form id="loginForm">
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" placeholder="your@email.com" autocomplete="email" required />
        </div>
        <div class="field">
          <label for="pin">PIN</label>
          <input type="password" id="pin" placeholder="Enter your PIN" autocomplete="current-password" required />
        </div>
        <button type="submit" class="login-btn">Enter Dashboard</button>
        <div id="loginError" class="login-err"></div>
      </form>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById("loginForm") as HTMLFormElement;
  const errorEl = document.getElementById("loginError") as HTMLDivElement;
  const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.style.display = "none";
    const email = (document.getElementById("email") as HTMLInputElement).value.trim();
    const pin = (document.getElementById("pin") as HTMLInputElement).value;
    btn.disabled = true;
    btn.textContent = "Signing in…";
    try {
      const res = await fetch("/api/auth/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, pin }),
      });
      if (res.ok) {
        window.location.href = "/dashboard";
      } else {
        const data = await res.json() as { error: string };
        errorEl.textContent = data.error ?? "Invalid credentials";
        errorEl.style.display = "block";
        btn.disabled = false;
        btn.textContent = "Enter Dashboard";
      }
    } catch {
      errorEl.textContent = "Network error — try again";
      errorEl.style.display = "block";
      btn.disabled = false;
      btn.textContent = "Enter Dashboard";
    }
  });
</script>
</Shell>
